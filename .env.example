# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model that plays the role of "your production prompt's" LLM
GROQ_MODEL=llama-3.1-8b-instant

# Model used as the judge that scores old vs new output against the golden reference.
# Can be the same model — kept separate in config so you can swap in a stronger judge.
JUDGE_MODEL=llama-3.1-8b-instant

# Semantic cache: skip re-scoring a (prompt, test_case) pair that's already been evaluated
CACHE_SIMILARITY_THRESHOLD=0.97

# How many golden cases to pull via hybrid search based on the prompt diff
BM25_TOP_K=10
VECTOR_TOP_K=10
FUSION_TOP_K=8

# How many of those survive reranking into the "smoke test" tier that always runs fast
RERANK_TOP_K=5

# Gate thresholds — breach any of these on a statistically significant delta -> FAIL
MAX_LENGTH_INCREASE_PCT=50
MAX_COST_INCREASE_PCT=30
MAX_LATENCY_INCREASE_PCT=50
MIN_JUDGE_SCORE=0.6
SIGNIFICANCE_ALPHA=0.05
